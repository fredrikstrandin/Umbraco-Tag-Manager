<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>TagManager</id>
    <version>17.0.0</version>
    <title>TagManager</title>
    <authors>ZAAKS!</authors>
    <license type="expression">MIT</license>
    <licenseUrl>https://licenses.nuget.org/MIT</licenseUrl>
    <icon>icon.png</icon>
    <readme>README.md</readme>
    <description>This package has been developed to provide a standard "Umbraco" interface to manage tags within your site.</description>
    <copyright>2026 © ZAAKS!</copyright>
    <tags>umbraco plugin package,umbraco-marketplace</tags>
    <repository type="git" url="https://github.com/usome/UmbracoTagManager" commit="0627cf4ee5b6c3a4dc45980136ee2d58eaf4ba0a" />
    <dependencies>
      <group targetFramework="net10.0">
        <dependency id="Umbraco.Cms.Api.Common" version="17.2.0" exclude="Build,Analyzers" />
        <dependency id="Umbraco.Cms.Api.Management" version="17.0.0" exclude="Build,Analyzers" />
        <dependency id="Umbraco.Cms.Web.Common" version="17.2.0" exclude="Build,Analyzers" />
        <dependency id="Umbraco.Cms.Web.Website" version="17.2.0" exclude="Build,Analyzers" />
      </group>
    </dependencies>
  </metadata>
</package>